# =============================================================================
# langgraph-checkpoint-neo4j local environment template
#
# Copy this file to `.env.local` and fill in the values you want to use.
#
# Supported model backends:
#   1. OpenAI hosted API
#   2. OpenAI-compatible local backend (for example vLLM)
#
# Notes:
# - The Python examples should prefer OPENAI_BASE_URL / OPENAI_API_KEY /
#   OPENAI_MODEL so they work with both OpenAI and vLLM.
# - `.env.local` is gitignored. Do not commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI-compatible backend
#
# OpenAI hosted API:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4.1
#
# Local vLLM example:
#   OPENAI_BASE_URL=http://localhost:7374/v1
#   OPENAI_API_KEY=dummy
#   OPENAI_MODEL=ministral-3b-instruct
# -----------------------------------------------------------------------------

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# -----------------------------------------------------------------------------
# Optional Anthropic config
#
# Not needed if you are only using OpenAI or an OpenAI-compatible backend.
# Leave blank unless you explicitly want Anthropic support in local examples.
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# npm publishing (local direnv integration)
#
# Used for local release/publish workflows that read NPM_TOKEN from `.env.local`.
# Keep this blank in template; set it only in your local `.env.local`.
# -----------------------------------------------------------------------------

NPM_TOKEN=

# -----------------------------------------------------------------------------
# Neo4j local development
#
# These defaults match the current docker-compose.yml host port mappings:
#   Browser: http://localhost:7373
#   Bolt:    bolt://localhost:7387
# -----------------------------------------------------------------------------

NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7387
NEO4J_HTTP_PORT=7373
NEO4J_URI=bolt://localhost:7387
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# Example/demo defaults
# -----------------------------------------------------------------------------

THREAD_ID=create-agent-demo

# -----------------------------------------------------------------------------
# Local AI / vLLM extras
#
# Used by the `ministral` service in docker-compose.yml when running with the
# `local-ai` profile.
# -----------------------------------------------------------------------------

HUGGINGFACEHUB_API_TOKEN=
MINISTRAL_PORT=7374
MINISTRAL_REPLICAS=0
