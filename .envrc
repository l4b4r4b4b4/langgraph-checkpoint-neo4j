# direnv configuration for local development.
#
# Behavior:
# - If `.env.local` exists, load it with direnv's `dotenv` helper.
# - If `.env.local` is missing, print a helpful message pointing to the
#   interactive bootstrap script.
#
# Usage:
#   direnv allow

if [ -f .env.local ]; then
  dotenv .env.local
else
  echo "Missing .env.local"
  echo "Create it from the template or run:"
  echo "  ./scripts/bootstrap-env-local.sh"
  echo
  echo "Template:"
  echo "  cp .env.local.example .env.local"
fi
