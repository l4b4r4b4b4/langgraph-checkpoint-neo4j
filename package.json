{
  "name": "langgraph-checkpoint-neo4j",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "lefthook install",
    "check:bun-version": "./scripts/check-bun-version.sh",
    "dev:python": "cd packages/python && uv run pytest --tb=short -q",
    "dev:ts": "cd packages/ts && bun test --watch",
    "test": "bun run test:python && bun run test:ts",
    "test:python": "cd packages/python && uv run pytest",
    "test:ts": "cd packages/ts && bun run test:bun",
    "test:ts:validation": "cd packages/ts && bun run test:validation",
    "test:ts:all": "cd packages/ts && bun run test:all",
    "lint": "bun run lint:python && bun run lint:ts",
    "lint:python": "cd packages/python && uv run ruff check . && uv run ruff format --check .",
    "lint:ts": "cd packages/ts && bunx tsc --noEmit",
    "format:python": "cd packages/python && uv run ruff check --fix --unsafe-fixes . && uv run ruff format .",
    "build:python": "cd packages/python && uv build",
    "build:ts": "cd packages/ts && bun run build",
    "neo4j:up": "docker compose up -d neo4j",
    "neo4j:down": "docker compose down neo4j",
    "submodule:update": "git submodule update --remote --merge"
  },
  "devDependencies": {
    "lefthook": "^2.1.0"
  }
}
